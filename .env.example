DATABASE_URL=postgres://postgres:postgres@postgres:5432/agentscope
SERVER_PORT=8080
LOG_LEVEL=info
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_EXPIRY_SECONDS=28800
SECURE_COOKIES=false
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agentscope
POSTGRES_PORT=5432
ANALYZE_COMPLETED_RUNS=false
ANALYZE_ROOT_CAUSES=false
ANALYSIS_POLL_INTERVAL_SECONDS=300
AGGREGATE_USAGE=true
USAGE_INTERVAL_SECONDS=3600
EVALUATE_ALERTS=true
ALERTS_INTERVAL_SECONDS=60
OIDC_OAUTH_CLIENT_ID=
OIDC_OAUTH_CLIENT_SECRET=
OIDC_OAUTH_REDIRECT_URI=
OIDC_OAUTH_ISSUER_URL=
# Comma-separated list of allowed frontend origins for browser calls.
# Example: https://agentscope-chi.vercel.app,http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
